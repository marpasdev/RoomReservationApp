<Window x:Class="RoomReservationSystem.Admin.StatisticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Statistics" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Period" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <Label Content="From"/>
                    <DatePicker x:Name="FromPicker"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,5,0">
                    <Label Content="To"/>
                    <DatePicker x:Name="ToPicker"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Load" 
                        VerticalAlignment="Bottom"
                        Click="Load_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Results" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="Room:" FontWeight="Bold" Width="180"/>
                    <Label x:Name="RoomNameLabel"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="Total Reservations:" FontWeight="Bold" Width="180"/>
                    <Label x:Name="TotalReservationsLabel"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="Occupancy Hours:" FontWeight="Bold" Width="180"/>
                    <Label x:Name="OccupancyHoursLabel"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="Occupancy Percentage:" FontWeight="Bold" Width="180"/>
                    <Label x:Name="OccupancyPercentageLabel"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <Button Grid.Row="2" Content="Close" 
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Click="Close_Click"/>
    </Grid>
</Window>