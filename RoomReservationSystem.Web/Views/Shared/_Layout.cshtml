<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RoomReservationSystem.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RoomReservationSystem.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Room Reservation
            </a>
            <div class="navbar-nav ms-auto">
                @if (User.Identity!.IsAuthenticated)
                {
                    <a class="nav-link" asp-controller="Reservations" asp-action="Index">
                        My Reservations
                    </a>
                    <a class="nav-link" asp-controller="Profile" asp-action="Index">
                        @User.Identity.Name
                    </a>
                    <a class="nav-link" asp-controller="Account" asp-action="Logout">
                        Logout
                    </a>
                }
                else
                {
                    <a class="nav-link" asp-controller="Account" asp-action="Login">
                        Login
                    </a>
                    <a class="nav-link" asp-controller="Account" asp-action="Register">
                        Register
                    </a>
                }
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - RoomReservationSystem.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
