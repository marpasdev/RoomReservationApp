@model IEnumerable<RoomReservationSystem.Shared.DTOs.Reservations.ReservationDto>
@{
    ViewData["Title"] = "Reservations";
}

<h2>My Reservations</h2>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Room</th>
            <th>From</th>
            <th>To</th>
            <th>Purpose</th>
            <th>Person Count</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reservation in Model)
        {
            <tr>
                <td>@reservation.RoomId</td>
                <td>@reservation.Start.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@reservation.End.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@reservation.Purpose</td>
                <td>@reservation.PersonCount</td>
                <td>
                    @if (reservation.Status == RoomReservationSystem.Shared.Enums.ReservationStatus.Active)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Cancelled</span>
                    }
                </td>
                <td>
                    @if (reservation.CanBeEdited == true)
                    {
                        <a asp-controller="ReservationsMvc" asp-action="Edit"
                           asp-route-id="@reservation.Id" class="btn btn-sm btn-warning">Edit</a>
                    }
                    @if (reservation.CanBeCancelled == true)
                    {
                        <form asp-controller="ReservationsMvc" asp-action="Cancel" method="post">
                            <input type="hidden" name="id" value="@reservation.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>