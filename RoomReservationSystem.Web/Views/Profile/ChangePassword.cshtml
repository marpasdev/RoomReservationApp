@model RoomReservationSystem.Shared.DTOs.Users.UpdatePasswordRequest
@{
    ViewData["Title"] = "Change password";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <h2>Change password</h2>
        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="OldPassword" class="form-label"></label>
                <input asp-for="OldPassword" type="password" class="form-control" />
                <span asp-validation-for="OldPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" type="password" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPasswordConfirmation" class="form-label"></label>
                <input asp-for="NewPasswordConfirmation" type="password" class="form-control" />
                <span asp-validation-for="NewPasswordConfirmation" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Change</button>
        </form>
    </div>
</div>
